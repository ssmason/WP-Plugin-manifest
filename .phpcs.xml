<?xml version="1.0"?>
<ruleset name="SatoriManifest">
	<description>PHPCS ruleset for Satori Manifest WordPress plugin.</description>

	<!-- Files to check -->
	<file>.</file>

	<!-- Exclusions -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/block/*</exclude-pattern>
	<exclude-pattern>*/src/scss/*</exclude-pattern>
	<exclude-pattern>*/languages/*</exclude-pattern>
	<exclude-pattern>*.js</exclude-pattern>
	<exclude-pattern>*.json</exclude-pattern>
	<exclude-pattern>webpack.config.js</exclude-pattern>

	<!-- Standards -->
	<rule ref="WordPress"/>

	<rule ref="WordPress-Docs"/>
	<rule ref="WordPress-Extra"/>

	<!-- PHP version -->
	<config name="minimum_supported_wp_version" value="6.4"/>
	<config name="testVersion" value="8.1-8.2"/>

	<!-- Use tabs for indentation -->
	<rule ref="Generic.WhiteSpace.DisallowSpaceIndent"/>
	<rule ref="Generic.WhiteSpace.ScopeIndent">
		<properties>
			<property name="indent" value="4"/>
			<property name="tabIndent" value="true"/>
		</properties>
	</rule>

	<!-- Text domain -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="satori-manifest"/>
			</property>
		</properties>
	</rule>

	<!-- Prefix check -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="satori_manifest"/>
				<element value="SatoriManifest"/>
				<element value="SATORI_MANIFEST"/>
			</property>
		</properties>
	</rule>
</ruleset>
