{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "satori-manifest/price-list",
	"title": "Manifest",
	"category": "widgets",
	"icon": "list-view",
	"description": "Display a structured price list with sections and items. Powered by Satori Manifest.",
	"keywords": [ "price", "list", "menu", "services", "manifest" ],
	"textdomain": "satori-manifest",
	"render": "file:./render.php",
	"editorScript": "file:./build/index.js",
	"editorStyle": "file:../src/scss/editor/build/editor.css",
	"style": "file:../src/scss/frontend/build/frontend.css",
	"attributes": {
		"manifestIds": {
			"type": "array",
			"items": { "type": "number" },
			"default": []
		},
		"layout": {
			"type": "string",
			"default": "single-column",
			"enum": [ "single-column", "two-column", "card-style", "minimal" ]
		},
		"colorScheme": {
			"type": "string",
			"default": "default",
			"enum": [ "default", "warm", "terracotta", "dark", "minimal" ]
		},
		"showPrices": {
			"type": "boolean",
			"default": true
		},
		"showDescriptions": {
			"type": "boolean",
			"default": true
		},
		"pricePrefix": {
			"type": "string",
			"default": ""
		},
		"customBgColor": {
			"type": "string",
			"default": ""
		},
		"customAccentColor": {
			"type": "string",
			"default": ""
		},
		"showBackground": {
			"type": "boolean",
			"default": true
		},
		"titleBgColor": {
			"type": "string",
			"default": ""
		},
		"customTitleColor": {
			"type": "string",
			"default": ""
		},
		"titleFontSize": {
			"type": "number",
			"default": 0
		},
		"titleFontWeight": {
			"type": "string",
			"default": ""
		},
		"titleFontFamily": {
			"type": "string",
			"default": ""
		},
		"itemFontSize": {
			"type": "number",
			"default": 0
		},
		"itemFontWeight": {
			"type": "string",
			"default": ""
		},
		"itemFontFamily": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"padding": true,
			"margin": true
		},
		"typography": {
			"fontSize": true
		}
	}
}
