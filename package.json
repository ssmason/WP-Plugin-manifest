{
	"name": "satori-manifest",
	"version": "1.0.0",
	"description": "WordPress plugin for structured price lists with a Gutenberg block.",
	"author": "Stephen Mason <steve@satori-digital.com>",
	"license": "GPL-2.0-or-later",
	"scripts": {
		"build": "webpack --mode production",
		"dev": "webpack --mode development --watch",
		"lint:js": "eslint \"block/src/**/*.js\"",
		"lint:scss": "stylelint \"src/scss/**/*.scss\"",
		"lint:php": "phpcs --standard=.phpcs.xml .",
		"pot": "wp i18n make-pot . languages/satori-manifest.pot",
		"test:php": "wp-env run tests-cli bash -c 'cd /var/www/html/wp-content/plugins/wp-satori-manifest && composer install --no-interaction --quiet && phpunit'",
		"cypress:open": "cypress open",
		"cypress:run": "cypress run"
	},
	"devDependencies": {
		"@babel/core": "^7.24.0",
		"@babel/preset-env": "^7.24.0",
		"@babel/preset-react": "^7.24.0",
		"@wordpress/eslint-plugin": "^21.0.0",
		"@wordpress/scripts": "^30.0.0",
		"@wordpress/stylelint-config": "^23.0.0",
		"babel-loader": "^9.1.3",
		"css-loader": "^7.1.2",
		"cypress": "^13.17.0",
		"mini-css-extract-plugin": "^2.9.2",
		"sass": "^1.83.0",
		"sass-loader": "^16.0.4",
		"stylelint": "^16.12.0",
		"webpack": "^5.97.1",
		"webpack-cli": "^5.1.4"
	}
}
